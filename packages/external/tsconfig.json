{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ludocode/util": ["../util"],
      "@ludocode/util/*": ["../util/*"],
      "@ludocode/api": ["../api"],
      "@ludocode/api/*": ["../api/*"],
      "@ludocode/design-system": ["../design-system"],
      "@ludocode/design-system/*": ["../design-system/*"],
      "@ludocode/types": ["../types"],
      "@ludocode/types/*": ["../types/*"],
      "@ludocode/hooks": ["../hooks"],
      "@ludocode/hooks/*": ["../hooks/*"],
      "@ludocode/external": ["."],
      "@ludocode/external/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
