{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ludocode/util": ["../util"],
      "@ludocode/util/*": ["../util/*"],
      "@ludocode/api": ["../api"],
      "@ludocode/api/*": ["../api/*"],
      "@ludocode/design-system": ["."],
      "@ludocode/design-system/*": ["./*"],
      "@ludocode/types": ["../types"],
      "@ludocode/types/*": ["../types/*"],
      "@ludocode/hooks": ["../hooks"],
      "@ludocode/hooks/*": ["../hooks/*"],
      "@ludocode/ludo-mdx": ["../ludo-mdx"],
      "@ludocode/ludo-mdx/*": ["../ludo-mdx/*"],
      "@ludocode/external": ["../external"],
      "@ludocode/external/*": ["../external/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../hooks/index.ts",
    "../types/index.ts",
    "../ludo-mdx/**/*.mdx",
    "../external/**/*.ts",
    "../external/**/*.tsx"
  ]
}
