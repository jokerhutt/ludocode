{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ludocode/util": ["../util"],
      "@ludocode/util/*": ["../util/*"],
      "@ludocode/api": ["../api"],
      "@ludocode/api/*": ["../api/*"],
      "@ludocode/design-system": ["../design-system"],
      "@ludocode/design-system/*": ["../design-system/*"],
      "@ludocode/types": ["."],
      "@ludocode/types/*": ["./*"],
      "@ludocode/hooks": ["../hooks"],
      "@ludocode/hooks/*": ["../hooks/*"],
      "@ludocode/external": ["../external"],
      "@ludocode/external/*": ["../external/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../apps/web/src/features/onboarding/Templates/OnboardingSteps.ts"
  ]
}
